# Test files (not needed in production)
out/test/**
src/test/**
test/**
*.test.js
*.test.ts

# Development files (but keep node_modules dependencies)
.git/**
.vscode/**
.vscode-test/**
scripts/**
!scripts/*.md

# Exclude most of node_modules but keep strip-ansi
node_modules/*
!node_modules/strip-ansi
!node_modules/strip-ansi/**/*
!node_modules/ansi-regex
!node_modules/ansi-regex/**/*

# Build outputs - include all out files
out/**
!out/extension.js
!out/extension.js.map
!out/cleaner.js
!out/cleaner.js.map
!out/security.js
!out/security.js.map
!out/privacyCommands.js
!out/privacyCommands.js.map
!out/terminalHistoryProvider.js
!out/terminalHistoryProvider.js.map
!out/commandHistoryItem.js
!out/commandHistoryItem.js.map
!out/constants/**/*.js
!out/constants/**/*.js.map
!out/enums/**/*.js
!out/enums/**/*.js.map
!out/interfaces/**/*.js
!out/interfaces/**/*.js.map

# Documentation
!README.md
!LICENSE.md
CHANGELOG.md
RELEASE-NOTES.md
ROADMAP/**
docs/**

# Temporary files
*.log
*.tmp
.DS_Store

# Binary files
bin/
*.vsix

# Exclude source files from the package
src/
