{
  "name": "terminal-history-outline",
  "displayName": "Terminal Velocity",
  "description": "View and manage your terminal command history directly in the VS Code Explorer outline view.",
  "version": "1.0.1",
  "publisher": "CoreyHamren",
  "repository": {
    "type": "git",
    "url": "https://github.com/chamren86/terminal-velocity.git"
  },
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "type": "module",
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "vitest run",
    "test:unit": "vitest run --reporter=verbose",
    "test:full": "npm run clean && npm install && npm run compile && npm test",
    "test:coverage": "vitest run --coverage",
    "precommit": "./scripts/precommit.sh",
    "prepush": "npm run test:full",
    "clean": "rm -rf out node_modules",
    "quick": "./scripts/quick-test.sh",
    "package": "vsce package",
    "build": "npm run compile && npm run package",
    "update": "./scripts/update.sh"
  },
  "dependencies": {
    "ansi-regex": "^6.0.1",
    "strip-ansi": "^7.2.0"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/vscode": "^1.93.0",
    "@vscode/vsce": "^3.9.2",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "contributes": {
    "commands": [
      {
        "command": "terminalHistory.clear",
        "title": "Clear Terminal History",
        "icon": "$(trash)"
      },
      {
        "command": "terminalHistory.rerun",
        "title": "Rerun Command",
        "icon": "$(play)"
      },
      {
        "command": "terminalHistory.copyCommand",
        "title": "Copy Command",
        "icon": "$(repl)"
      },
      {
        "command": "terminalHistory.copyOutput",
        "title": "Copy Output",
        "icon": "$(output)"
      },
      {
        "command": "terminalHistory.copyCommandAndOutput",
        "title": "Copy Command and Output",
        "icon": "$(copy)"
      },
      {
        "command": "terminalHistory.deleteEntry",
        "title": "Delete Entry",
        "icon": "$(close)"
      },
      {
        "command": "terminalHistory.privacyDashboard",
        "title": "Privacy Dashboard",
        "icon": "$(shield)"
      },
      {
        "command": "terminalHistory.showActions",
        "title": "Show Actions",
        "icon": "$(ellipsis)"
      },
      {
        "command": "terminalHistory.searchHistory",
        "title": "Search History",
        "icon": "$(filter)"
      },
      {
        "command": "terminalHistory.clearFilter",
        "title": "Clear Filter",
        "icon": "$(clear-all)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "terminalHistory.clear",
          "group": "navigation",
          "when": "view == terminalHistory"
        },
        {
          "command": "terminalHistory.searchHistory",
          "group": "navigation",
          "when": "view == terminalHistory"
        },
        {
          "command": "terminalHistory.clearFilter",
          "group": "navigation",
          "when": "view == terminalHistory && terminalHistory:filterActive"
        },
        {
          "command": "terminalHistory.privacyDashboard",
          "group": "navigation",
          "when": "view == terminalHistory"
        }
      ],
      "view/item/context": [
        {
          "command": "terminalHistory.rerun",
          "when": "view == terminalHistory && viewItem == historyItem",
          "group": "inline"
        },
        {
          "command": "terminalHistory.copyCommand",
          "when": "view == terminalHistory && viewItem == historyItem",
          "group": "inline"
        },
        {
          "command": "terminalHistory.copyOutput",
          "when": "view == terminalHistory && viewItem == historyItem",
          "group": "inline"
        },
        {
          "command": "terminalHistory.copyCommandAndOutput",
          "when": "view == terminalHistory && viewItem == historyItem",
          "group": "inline"
        },
        {
          "command": "terminalHistory.deleteEntry",
          "when": "view == terminalHistory && viewItem == historyItem",
          "group": "inline"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "terminalHistory",
          "name": "Terminal History"
        }
      ]
    },
    "configuration": {
      "title": "Terminal Velocity",
      "properties": {
        "terminalHistory.maxHistorySize": {
          "type": "number",
          "default": 100,
          "description": "Maximum number of commands to store in history"
        },
        "terminalHistory.security.detectionEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable sensitive data detection"
        },
        "terminalHistory.security.redactionLevel": {
          "type": "string",
          "enum": [
            "off",
            "warn",
            "redact",
            "block"
          ],
          "default": "warn",
          "description": "How to handle sensitive data"
        },
        "terminalHistory.security.warnOnDetection": {
          "type": "boolean",
          "default": true,
          "description": "Show warning when sensitive data is detected"
        },
        "terminalHistory.security.customPatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Custom regex patterns for sensitive data detection"
        },
        "terminalHistory.security.excludedCommands": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Commands to exclude from history (regex supported)"
        }
      }
    }
  },
  "allowScripts": {
    "@vscode/vsce-sign@2.0.9": true,
    "keytar@7.9.0": true
  }
}
