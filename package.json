{
  "name": "terminal-history-outline",
  "displayName": "Terminal History Outline",
  "description": "View and manage terminal command history in the Explorer outline view",
  "version": "0.2.0",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "terminalHistoryOutline",
          "name": "Terminal History",
          "icon": "$(history)"
        }
      ]
    },
    "commands": [
      {
        "command": "terminalHistory.clear",
        "title": "Clear Terminal History",
        "icon": "$(clear-all)"
      },
      {
        "command": "terminalHistory.rerun",
        "title": "Rerun Command",
        "icon": "$(run)"
      },
      {
        "command": "terminalHistory.copyOutput",
        "title": "Copy Output",
        "icon": "$(copy)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "terminalHistory.clear",
          "when": "view == terminalHistoryOutline",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "terminalHistory.rerun",
          "when": "viewItem == commandItem",
          "group": "inline"
        },
        {
          "command": "terminalHistory.copyOutput",
          "when": "viewItem == commandItem",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Terminal History Outline",
      "properties": {
        "terminalHistory.maxHistorySize": {
          "type": "number",
          "default": 100,
          "description": "Maximum number of commands to keep in history"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && mocha --ui tdd 'out/test/unit/**/*Test.js'"
  },
  "c8": {
    "reporter": [
      "text",
      "lcov",
      "html"
    ],
    "include": [
      "src/**/*.ts"
    ],
    "exclude": [
      "src/test/**/*.ts"
    ]
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/strip-ansi": "^3.0.0",
    "@types/vscode": "^1.93.0",
    "@vscode/test-electron": "^3.0.0",
    "c8": "^11.0.0",
    "chai": "^6.2.2",
    "mocha": "^11.7.6",
    "typescript": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chamren86/terminal-history-outline.git"
  },
  "author": "chamren86",
  "license": "MIT",
  "publisher": "chamren86",
  "dependencies": {
    "strip-ansi": "^7.2.0"
  }
}
