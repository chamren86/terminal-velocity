{
  "name": "terminal-history-outline",
  "type": "module",
  "displayName": "Terminal History Outline",
  "description": "View and manage terminal command history in the Explorer outline view",
  "version": "0.4.3",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "terminalHistoryOutline",
          "name": "Terminal History",
          "icon": "$(history)"
        }
      ]
    },
    "commands": [
      {
        "command": "terminalHistory.clear",
        "title": "Clear Terminal History",
        "icon": "$(clear-all)"
      },
      {
        "command": "terminalHistory.rerun",
        "title": "Rerun Command",
        "icon": "$(run)"
      },
      {
        "command": "terminalHistory.copyOutput",
        "title": "Copy Output",
        "icon": "$(copy)"
      },
      {
        "command": "terminalHistory.privacyDashboard",
        "title": "Privacy Dashboard",
        "icon": "$(shield)"
      },
      {
        "command": "terminalHistory.clearSensitive",
        "title": "Clear Sensitive Commands",
        "icon": "$(trash)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "terminalHistory.clear",
          "when": "view == terminalHistoryOutline",
          "group": "navigation"
        },
        {
          "command": "terminalHistory.privacyDashboard",
          "when": "view == terminalHistoryOutline",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "terminalHistory.rerun",
          "when": "viewItem == commandItem",
          "group": "inline"
        },
        {
          "command": "terminalHistory.copyOutput",
          "when": "viewItem == commandItem",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Terminal History Outline",
      "properties": {
        "terminalHistory.maxHistorySize": {
          "type": "number",
          "default": 100,
          "description": "Maximum number of commands to keep in history"
        },
        "terminalHistory.security.detectionEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable sensitive data detection in commands"
        },
        "terminalHistory.security.redactionLevel": {
          "type": "string",
          "enum": [
            "off",
            "warn",
            "redact",
            "block"
          ],
          "default": "warn",
          "description": "How to handle sensitive data: off (ignore), warn (show warning), redact (replace with [REDACTED]), block (don't save)"
        },
        "terminalHistory.security.warnOnDetection": {
          "type": "boolean",
          "default": true,
          "description": "Show warning notification when sensitive data is detected"
        },
        "terminalHistory.security.customPatterns": {
          "type": "array",
          "default": [],
          "description": "Custom regex patterns for detecting sensitive data",
          "items": {
            "type": "string"
          }
        },
        "terminalHistory.security.excludedCommands": {
          "type": "array",
          "default": [],
          "description": "Commands matching these patterns will not be saved (regex supported)",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "./scripts/build.sh",
    "watch": "tsc -watch -p ./",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "./scripts/unit-test.sh",
    "test:full": "./scripts/test.sh",
    "test:act": "act -j test --pull=false",
    "precommit": "./scripts/precommit.sh",
    "prepush": "./scripts/prepush.sh",
    "quick": "./scripts/quick-test.sh",
    "package": "vsce package",
    "build": "npm run compile && npm run package"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.93.0",
    "mocha": "^10.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^5.0.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "strip-ansi": "^7.2.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chamren86/terminal-history-outline.git"
  },
  "author": "chamren86",
  "license": "MIT",
  "publisher": "chamren86"
}
