import * as assert from 'assert';
import {
    detectSensitiveData,
    redactSensitiveData,
    isExcludedCommand,
    SENSITIVE_PATTERNS
} from '../../security';
import { SENSITIVE_SAMPLES } from '../fixtures/sampleOutputs';

suite('Security Tests', () => {
    test('Should detect passwords', () => {
        const result = detectSensitiveData(SENSITIVE_SAMPLES.password);
        assert.strictEqual(result.some(p => p.name === 'password'), true);
    });

    test('Should detect API keys', () => {
        const result = detectSensitiveData(SENSITIVE_SAMPLES.apiKey);
        assert.strictEqual(result.some(p => p.name === 'api-key'), true);
    });

    test('Should detect AWS keys', () => {
        const result = detectSensitiveData(SENSITIVE_SAMPLES.awsKey);
        assert.strictEqual(result.some(p => p.name === 'aws-key'), true);
    });

    test('Should detect JWT tokens', () => {
        const result = detectSensitiveData(SENSITIVE_SAMPLES.jwt);
        assert.strictEqual(result.some(p => p.name === 'jwt-token'), true);
    });

    test('Should detect GitHub tokens', () => {
        const result = detectSensitiveData(SENSITIVE_SAMPLES.githubToken);
        assert.strictEqual(result.some(p => p.name === 'github-token'), true);
    });

    test('Should detect Slack tokens', () => {
        const result = detectSensitiveData(SENSITIVE_SAMPLES.slackToken);
        assert.strictEqual(result.some(p => p.name === 'slack-token'), true);
    });

    test('Should detect SSH keys', () => {
        const result = detectSensitiveData(SENSITIVE_SAMPLES.sshKey);
        assert.strictEqual(result.some(p => p.name === 'ssh-key'), true);
    });

    test('Should redact passwords preserving structure', () => {
        const result = redactSensitiveData(SENSITIVE_SAMPLES.password);
        assert.strictEqual(result.includes('MySecretPassword123'), false);
        assert.strictEqual(result.includes('[REDACTED]'), true);
        assert.strictEqual(result.includes('mysql -u root -p'), true);
    });

    test('Should redact API keys preserving structure', () => {
        const result = redactSensitiveData(SENSITIVE_SAMPLES.apiKey);
        assert.strictEqual(result.includes('sk-abc123xyz789'), false);
        assert.strictEqual(result.includes('[REDACTED]'), true);
        assert.strictEqual(result.includes('curl -H "Authorization: Bearer'), true);
    });

    test('Should redact AWS keys', () => {
        const result = redactSensitiveData(SENSITIVE_SAMPLES.awsKey);
        assert.strictEqual(result.includes('AKIAIOSFODNN7EXAMPLE'), false);
        assert.strictEqual(result.includes('[REDACTED]'), true);
        assert.strictEqual(result.includes('AWS_ACCESS_KEY_ID='), true);
    });

    test('Should exclude commands matching patterns', () => {
        // Set up test config - we'll need to mock this in real tests
        // For now, test the function with custom patterns
        const config = {
            excludedCommands: ['.*password.*', '.*secret.*', 'mysql.*']
        };
        
        // This would need the actual config to work
        // For now, we test the pattern matching logic
        const testPattern = /.*password.*/i;
        assert.strictEqual(testPattern.test('mysql -p'), true);
        assert.strictEqual(testPattern.test('ls -la'), false);
    });

    test('Should not flag normal commands as sensitive', () => {
        const result = detectSensitiveData('ls -la');
        assert.strictEqual(result.length, 0);
        
        const result2 = detectSensitiveData('echo "Hello World"');
        assert.strictEqual(result2.length, 0);
        
        const result3 = detectSensitiveData('npm install');
        assert.strictEqual(result3.length, 0);
    });

    test('Sensitive patterns should be case insensitive', () => {
        const result = detectSensitiveData('PASSWORD=secret123');
        assert.strictEqual(result.some(p => p.name === 'password'), true);
        
        const result2 = detectSensitiveData('Bearer token123');
        assert.strictEqual(result2.some(p => p.name === 'jwt-token'), true);
    });
});